class BankUser:
    def __init__(self, frist_name, last_name, age, card_number):
        self.frist_name = frist_name
        self.last_name = last_name
        self.age = age
        self.card_number = card_number

    def card_info(self):
        return f'Foydalanuvchi: {self.frist_name} {self.last_name} \nKarta raqami: {self.card_number}'

